<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Executor Status Monitor</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Poppins', system-ui, -apple-system, BlinkMacSystemFont, 'Roboto', sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(145deg, #0a0f1e 0%, #0c1222 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 1.5rem;
        }

        /* Main card container */
        .status-card {
            max-width: 550px;
            width: 100%;
            background: rgba(18, 25, 45, 0.75);
            backdrop-filter: blur(12px);
            border-radius: 2.5rem;
            border: 1px solid rgba(66, 153, 225, 0.2);
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.02) inset;
            overflow: hidden;
            transition: all 0.2s ease;
        }

        /* Header with neon accent */
        .header {
            background: rgba(10, 14, 23, 0.7);
            padding: 1.5rem 1.8rem;
            border-bottom: 1px solid rgba(66, 153, 225, 0.3);
            text-align: center;
        }

        .header h1 {
            font-size: 1.9rem;
            font-weight: 700;
            background: linear-gradient(135deg, #ffffff, #a0c4ff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.3px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .header h1 span {
            font-size: 2rem;
        }

        .sub {
            color: #8a9bb5;
            margin-top: 0.5rem;
            font-size: 0.85rem;
            font-weight: 500;
        }

        /* Status items container */
        .status-list {
            padding: 1.8rem 2rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* Individual status row */
        .status-item {
            background: rgba(12, 18, 32, 0.6);
            border-radius: 1.8rem;
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            backdrop-filter: blur(4px);
            transition: transform 0.2s, box-shadow 0.2s;
            border: 1px solid rgba(255, 255, 255, 0.03);
        }

        .status-item:hover {
            transform: translateY(-2px);
            background: rgba(20, 30, 50, 0.7);
            border-color: rgba(66, 153, 225, 0.3);
            box-shadow: 0 8px 20px -8px rgba(0, 0, 0, 0.4);
        }

        .info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .icon {
            font-size: 2.2rem;
            width: 48px;
            text-align: center;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
        }

        .platform {
            font-weight: 600;
            font-size: 1.25rem;
            letter-spacing: -0.2px;
            color: #eef4ff;
        }

        .badge {
            font-size: 0.75rem;
            background: rgba(255,255,255,0.08);
            padding: 0.2rem 0.6rem;
            border-radius: 40px;
            color: #b9c8ff;
        }

        /* Status indicator (dot + text) */
        .status-indicator {
            display: flex;
            align-items: center;
            gap: 0.65rem;
            background: rgba(0, 0, 0, 0.4);
            padding: 0.4rem 1rem;
            border-radius: 60px;
        }

        .dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            box-shadow: 0 0 6px currentColor;
            transition: all 0.2s;
        }

        .dot.green {
            background-color: #2ee68f;
            box-shadow: 0 0 8px #2ee68f;
        }

        .dot.red {
            background-color: #ff5c5c;
            box-shadow: 0 0 8px #ff5c5c;
        }

        .status-text {
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.3px;
        }

        .green-text {
            color: #6effb0;
        }

        .red-text {
            color: #ff8a8a;
        }

        /* live timestamp footer */
        .footer {
            background: rgba(0, 0, 0, 0.3);
            padding: 1rem 1.8rem;
            text-align: center;
            font-size: 0.7rem;
            color: #5f738c;
            border-top: 1px solid rgba(255, 255, 255, 0.03);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .refresh-btn {
            background: #1f2a44;
            border: none;
            color: #bdd4ff;
            padding: 0.3rem 1rem;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

        .refresh-btn:hover {
            background: #2d3b60;
            color: white;
        }

        @media (max-width: 480px) {
            .status-list {
                padding: 1.2rem;
            }
            .platform {
                font-size: 1rem;
            }
            .icon {
                font-size: 1.8rem;
                width: 40px;
            }
            .status-item {
                padding: 0.8rem 1rem;
            }
        }
    </style>
</head>
<body>

<div class="status-card">
    <div class="header">
        <h1>
            <span>⚡</span> Executor status
        </h1>
        <div class="sub"></div>
    </div>

    <div class="status-list">
        <!-- Android row (🟢 ONLINE) -->
        <div class="status-item">
            <div class="info">
                <div class="icon">📱</div>
                <div>
                    <div class="platform">Android Executor</div>
                    <div class="badge">status</div>
                </div>
            </div>
            <div class="status-indicator">
                <div class="dot green"></div>
                <div class="status-text green-text">ONLINE ● ACTIVE</div>
            </div>
        </div>

        <!-- Windows row (🔴 OFFLINE) -->
        <div class="status-item">
            <div class="info">
                <div class="icon">🪟</div>
                <div>
                    <div class="platform">Windows Executor</div>
                    <div class="badge">status</div>
                </div>
            </div>
            <div class="status-indicator">
                <div class="dot red"></div>
                <div class="status-text red-text">OFFLINE ● UNAVAILABLE</div>
            </div>
        </div>
    </div>

    <div class="footer">
        <span>Made by rtao_rs3 <span id="timestamp">just now</span></span>
        <button class="refresh-btn" id="refreshStatus">⟳ refresh</button>
    </div>
</div>

<script>
    // dynamic timestamp with optional "simulated status check"
    const timestampEl = document.getElementById('timestamp');
    
    function updateTimestamp() {
        const now = new Date();
        const formatted = now.toLocaleTimeString([], { hour: '2-digit', minute:'2-digit', second:'2-digit' });
        timestampEl.innerText = formatted;
    }
    
    // initial timestamp
    updateTimestamp();
    
    // refresh button: update timestamp and could simulate ping check
    const refreshBtn = document.getElementById('refreshStatus');
    refreshBtn.addEventListener('click', () => {
        updateTimestamp();
        // optional micro animation for feedback
        refreshBtn.style.transform = 'scale(0.96)';
        setTimeout(() => { refreshBtn.style.transform = ''; }, 120);
        
        // you can also send a visual "check" effect on the status dots
        const dots = document.querySelectorAll('.dot');
        dots.forEach(dot => {
            dot.style.opacity = '0.7';
            setTimeout(() => { dot.style.opacity = '1'; }, 150);
        });
    });
    
    // automatic time update every second (shows live)
    setInterval(updateTimestamp, 1000);
    
    // Optional: simulate health check if you ever want to toggle via api
    // For this demo, Android is hardcoded green, Windows red.
    // (static representation, but fully matches your requirement)
    console.log('Executor Status UI — Android 🟢 / Windows 🔴');
</script>

</body>
</html>
