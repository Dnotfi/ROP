<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Discord Webhook Chat · Simple</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #0a0c15;
            font-family: 'Inter', system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #eef2ff;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            width: 100%;
            background: #0f172a;
            border-radius: 32px;
            border: 1px solid #2d3a5e;
            overflow: hidden;
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.4);
        }

        .header {
            background: #1e293b;
            padding: 16px 24px;
            text-align: center;
            border-bottom: 1px solid #2d3a5e;
        }
        .header i {
            font-size: 48px;
            color: #5865f2;
        }
        .header h1 {
            font-size: 24px;
            font-weight: 700;
            margin-top: 8px;
        }
        .header p {
            font-size: 13px;
            color: #94a3b8;
            margin-top: 4px;
        }

        .content {
            padding: 24px;
        }

        .input-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #94a3b8;
            margin-bottom: 6px;
        }
        input, textarea {
            width: 100%;
            background: #1e293b;
            border: 1px solid #2d3a5e;
            border-radius: 16px;
            padding: 12px 16px;
            color: white;
            font-size: 14px;
            outline: none;
            font-family: inherit;
        }
        textarea {
            resize: vertical;
            min-height: 100px;
        }
        input:focus, textarea:focus {
            border-color: #5865f2;
        }

        .preview {
            background: #1e293b;
            border-radius: 16px;
            padding: 16px;
            margin-top: 16px;
            margin-bottom: 20px;
        }
        .preview-title {
            font-size: 11px;
            color: #94a3b8;
            margin-bottom: 8px;
        }
        .message-preview {
            background: #0a0c15;
            border-radius: 12px;
            padding: 12px;
            border-left: 4px solid #5865f2;
            font-size: 13px;
            word-break: break-word;
        }

        button {
            background: #5865f2;
            border: none;
            width: 100%;
            padding: 14px;
            border-radius: 40px;
            color: white;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        button:hover {
            background: #4752c4;
            transform: scale(1.01);
        }

        .log {
            background: #0a0c15;
            border-radius: 16px;
            padding: 12px;
            margin-top: 20px;
            font-family: monospace;
            font-size: 11px;
            max-height: 150px;
            overflow-y: auto;
        }
        .log-line {
            padding: 4px 0;
            color: #86efac;
            border-bottom: 1px solid #1e293b;
        }
        .log-error {
            color: #f87171;
        }

        footer {
            background: #0a0c15;
            padding: 12px;
            text-align: center;
            font-size: 10px;
            color: #4b5563;
            border-top: 1px solid #1e293b;
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <i class="fab fa-discord"></i>
        <h1>Discord Webhook</h1>
        <p>Send messages to any Discord channel via webhook</p>
    </div>

    <div class="content">
        <div class="input-group">
            <label><i class="fab fa-discord"></i> Webhook URL</label>
            <input type="text" id="webhookUrl" placeholder="https://discord.com/api/webhooks/.../...">
        </div>

        <div class="input-group">
            <label><i class="fas fa-comment"></i> Message</label>
            <textarea id="message" placeholder="Type your message here..."></textarea>
        </div>

        <div class="preview">
            <div class="preview-title">Preview (how it will Discord)</div>
            <div class="message-preview" id="previewMsg">
                Your message will appear here...
            </div>
        </div>

        <button id="sendBtn"><i class="fab fa-discord"></i> Send to Discord</button>

        <div class="log" id="logArea">
            <div class="log-line">> Ready to send messages</div>
        </div>
    </div>

    <footer>
        <i class="fas fa-shield-alt"></i> Discord webhook
    </footer>
</div>

<script>
    const webhookInput = document.getElementById('webhookUrl');
    const messageInput = document.getElementById('message');
    const sendBtn = document.getElementById('sendBtn');
    const logArea = document.getElementById('logArea');
    const previewMsg = document.getElementById('previewMsg');

    function updatePreview() {
        const message = messageInput.value.trim() || "";
        previewMsg.innerText = message;
    }

    function escapeHtml(str) {
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    function addLog(text, isError = false) {
        const line = document.createElement('div');
        line.className = 'log-line' + (isError ? ' log-error' : '');
        const time = new Date().toLocaleTimeString();
        line.innerHTML = `> [${time}] ${escapeHtml(text)}`;
        logArea.appendChild(line);
        logArea.scrollTop = logArea.scrollHeight;
        while (logArea.children.length > 50) logArea.removeChild(logArea.firstChild);
    }

    async function sendWebhook() {
        let webhookUrl = webhookInput.value.trim();
        if (!webhookUrl) {
            addLog('❌ Please enter a webhook URL', true);
            return;
        }
        const message = messageInput.value.trim();
        if (!message) {
            addLog('Message cannot be empty', true);
            return;
        }

        const payload = { content: message };

        addLog(`Sending webhook to ${webhookUrl.substring(0, 50)}...`);

        try {
            const response = await fetch(webhookUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (response.ok) {
                addLog(`Message sent successfully`);
                messageInput.value = '';
                updatePreview();
            } else {
                const errorText = await response.text();
                addLog(`Webhook error (${response.status}): ${errorText.substring(0, 150)}`, true);
            }
        } catch (err) {
            addLog(`Network error: ${err.message}`, true);
        }
    }

    sendBtn.addEventListener('click', sendWebhook);
    messageInput.addEventListener('input', updatePreview);
    updatePreview();

    // Enter key shortcut (Ctrl+Enter)
    messageInput.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            e.preventDefault();
            sendWebhook();
        }
    });
</script>
</body>
</html>
